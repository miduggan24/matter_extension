  - path: Engine.h
  - path: Generations.h
  - path: ReportScheduler.h
  - path: ReportSchedulerImpl.h
  - path: SynchronizedReportSchedulerImpl.h
  - path: reporting.h
label: interaction_model
package: matter
provides:
- name: matter_interaction_model
quality: production
metadata:
  sbom:
    license: Apache 2.0
source:
