id: matter_test_event_trigger
label: Matter Test Event Trigger
description: Definition of the TestEventTriggerDelegate class. An application implementing
  the TestEventTrigger Command must enable this component and implement bool emberAfHandleEventTrigger(uint64_t).
package: matter
category: Stack
quality: production
metadata:
  sbom:
    license: Zlib
provides:
- name: matter_test_event_trigger
source:
- path: third_party/matter_sdk/examples/platform/silabs/test-event-trigger/SilabsTestEventTriggerDelegate.cpp
include:
- path: third_party/matter_sdk/examples/platform/silabs/test-event-trigger
  file_list:
  - path: SilabsTestEventTriggerDelegate.h
- path: third_party/matter_sdk/src/app
  file_list:
  - path: AppConfig.h
  - path: AttributeAccessInterface.h
  - path: AttributeAccessInterfaceCache.h
  - path: AttributeAccessInterfaceRegistry.h
  - path: AttributeAccessToken.h
  - path: AttributeEncodeState.h
