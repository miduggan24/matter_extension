  - path: TestEventTriggerDelegate.h
  - path: TimedHandler.h
  - path: TimedRequest.h
  - path: WriteClient.h
  - path: WriteHandler.h
config_file:
- path: slc/config/sl_matter_test_event_trigger_config.h
  file_id: matter_test_event_trigger_config
define:
- name: SL_MATTER_TEST_EVENT_TRIGGER_ENABLED
